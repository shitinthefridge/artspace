# ─────────────────────────────────────────────────────────────
# ARTSPACE — Environment Variables Template
# Copy to .env and fill in your real values
# ⚠️  NEVER commit .env to GitHub — it's blocked in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Supabase (get from supabase.com → your project → Settings → API) ──
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── Server-side Supabase (service role — NEVER expose to browser) ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ── Admin panel password ──
VITE_ADMIN_PASSWORD=change-me-to-something-private

# ── Studio branding (appears on portfolio pages) ──
VITE_TEACHER_NAME=Your Teacher Name
VITE_STUDIO_NAME=Your Studio Name

# ── Express server settings ──
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change_this_in_production

# ── Supabase Storage Bucket names ──
SUPABASE_STORAGE_BUCKET=artworks
